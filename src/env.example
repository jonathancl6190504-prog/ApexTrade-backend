# Polygon.io API Key (for market data)
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API Key (for market sentiment)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Initial balance for paper trading (in dollars)
INITIAL_BALANCE=100000

# Watch list (comma-separated symbols: ES, NQ, CL, AAPL, etc.)
WATCH_LIST=ES,NQ,CL

# REST API Port
PORT=3000

# WebSocket Port
WS_PORT=8080

# Environment (development or production)
NODE_ENV=development

# Railway Deployment URL (set after deploying to Railway)
RAILWAY_DEPLOYMENT_URL=https://your-backend.up.railway.app

# Mobile App Backend URL (used by React Native app)
MOBILE_BACKEND_URL=http://localhost:3000
